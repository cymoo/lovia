# Copy to .env and fill in. The examples and `lovia web` read this via
# python-dotenv. Precedence: CLI flag > environment > ./.env >
# ~/.config/lovia/config.env (written by `lovia web`'s first-run setup).

# Model — the single knob. "<vendor>:<model>"; a bare name routes to the
# OpenAI-compatible provider (the OPENAI_BASE_URL path).
LOVIA_MODEL=openai:gpt-5.5
# LOVIA_MODEL=anthropic:claude-4-8-opus

OPENAI_API_KEY=sk-...
# Any OpenAI-compatible service (DeepSeek, Ollama, vLLM, ...): point the base
# URL at it and set LOVIA_MODEL to its model id (e.g. openai:deepseek-v4-pro).
# OPENAI_BASE_URL=https://api.deepseek.com

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=

# Web search: `lovia web` prefers the Tavily backend when this is set;
# otherwise it falls back to the keyless DuckDuckGo backend (lovia[ddg]).
# TAVILY_API_KEY=tvly-...

# --- lovia web: image/file attachments ---
# The composer's "+" uploads images/files into the workspace's `uploads/` dir.
# Every attachment is referenced by path so the agent can open it with its file
# tools (works with any model). Images can additionally be *seen* two ways —
# pick whichever fits your setup:
#
# (a) Your MAIN model can see images -> send them inline. Official
#     api.openai.com / api.anthropic.com hosts are auto-detected; declare it for
#     any other endpoint (a DashScope/Qwen-VL or vLLM deployment):
# LOVIA_VISION=1
#
# (b) Your main model is text-only -> delegate to a SEPARATE vision model via a
#     `see_image` tool. The vendor prefix picks the API dialect, exactly like
#     LOVIA_MODEL: `openai:`/bare = OpenAI-compatible, `anthropic:` = Anthropic.
# LOVIA_VISION_MODEL=openai:qwen3.7-plus
#     Endpoint + key for that vision model — default to the OPENAI_*/ANTHROPIC_*
#     its prefix routes to; set these when it's on a different endpoint:
# LOVIA_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LOVIA_VISION_API_KEY=sk-...

# --- lovia web: upload limits (composer "+") ---
# Max upload size in MiB (default 25):
# LOVIA_MAX_UPLOAD_MB=25
# Extension allowlist (comma/space separated, no dots). Unset uses a built-in
# list of common image/doc/code types; "*" accepts any type:
# LOVIA_UPLOAD_ALLOWED_EXT=*
