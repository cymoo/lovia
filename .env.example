# Copy to .env and fill in the model section — that is all `lovia web` and the
# examples/ scripts need. Everything else is optional.
#
# Precedence: CLI flag > environment > .lovia/config.env > ./.env
# (.lovia/config.env is what `lovia web`'s first-run setup writes; this file is
# never written to.)

# --- model ---
# "<vendor>:<model>"; a bare name means "some OpenAI-compatible endpoint".
LOVIA_MODEL=openai:gpt-5.5
OPENAI_API_KEY=sk-...

# Any OpenAI-compatible service (DeepSeek, Ollama, vLLM, ...): point the base
# URL at it and keep using LOVIA_MODEL for its model id.
# OPENAI_BASE_URL=https://api.deepseek.com

# Anthropic instead: LOVIA_MODEL=anthropic:claude-4-8-opus
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=

# --- web search ---
# Set for the Tavily backend; unset falls back to keyless DuckDuckGo (lovia[ddg]).
# TAVILY_API_KEY=tvly-...

# --- images (lovia web) ---
# Uploads land in the workspace, so any model can open them by path with its
# file tools. To let a model actually *see* an image, pick one:
#
# (a) your main model is multimodal — official api.openai.com / api.anthropic.com
#     hosts are detected; declare it for any other endpoint (Qwen-VL, vLLM, ...):
# LOVIA_VISION=1
#
# (b) your main model is text-only — delegate to a separate vision model, which
#     lovia exposes as a `see_image` tool (vendor prefix as in LOVIA_MODEL):
# LOVIA_VISION_MODEL=openai:qwen3.7-plus
#     Its endpoint/key default to the OPENAI_* / ANTHROPIC_* pair above; set
#     these when the vision model lives elsewhere:
# LOVIA_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LOVIA_VISION_API_KEY=sk-...

# --- uploads (lovia web) ---
# LOVIA_MAX_UPLOAD_MB=25              # per-file limit, MiB
# LOVIA_UPLOAD_ALLOWED_EXT=*          # default: common image/doc/data/code types
