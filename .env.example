# Copy to .env and fill in. The examples and `lovia web` read this via
# python-dotenv. Precedence: CLI flag > environment > ./.env >
# ~/.config/lovia/config.env (written by `lovia web`'s first-run setup).

# Model used by every example: "<vendor>:<model>".
LOVIA_MODEL=openai:gpt-5.5
# LOVIA_MODEL=anthropic:claude-4-8-opus

# Optional second model for the fallback-chain demo (14_reliability.py).
# LOVIA_FALLBACK_MODEL=anthropic:claude-4-8-opus

OPENAI_API_KEY=sk-...
# Any OpenAI-compatible service (DeepSeek, Ollama, vLLM, ...):
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_DEFAULT_MODEL=deepseek-v4-pro

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=
